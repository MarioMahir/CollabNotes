@model CollabNotes.Web.Models.Notes.NotesIndexViewModel

@{
    ViewData["Title"] = "Mis notas";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Mis notas</h1>
</div>

<div class="row g-4">
    <div class="col-md-3">
        <div class="surface-card p-3 mb-3">
            <div class="collab-panel-title">Carpetas</div>
            <nav class="folder-nav mb-3">
                <a class="folder-nav-link @(Model.SelectedFolderId is null ? "active" : "")" asp-action="Index">
                    <span>Todas</span>
                </a>
                @foreach (var folder in Model.Folders)
                {
                    <a class="folder-nav-link @(Model.SelectedFolderId == folder.Id ? "active" : "")" asp-action="Index" asp-route-folderId="@folder.Id">
                        <span>@folder.Name</span>
                    </a>
                }
            </nav>

            <form asp-action="CreateFolder" method="post" class="d-flex">
                <input type="text" name="name" class="form-control form-control-sm me-2" placeholder="Nueva carpeta" required />
                <button type="submit" class="btn btn-sm btn-outline-secondary">Crear</button>
            </form>
        </div>
    </div>

    <div class="col-md-9">
        <a class="btn btn-primary mb-3" asp-action="Create" asp-route-folderId="@Model.SelectedFolderId">+ Nueva nota</a>

        @if (!Model.Notes.Any())
        {
            <div class="empty-state">
                <p class="mb-0">No hay notas todavía. Crea la primera para empezar a colaborar.</p>
            </div>
        }
        else
        {
            <div class="notes-grid">
                @foreach (var note in Model.Notes)
                {
                    <div class="note-card">
                        <a class="note-card-title" asp-action="Edit" asp-route-id="@note.Id">@note.Title</a>
                        <div class="note-card-meta">Actualizada: @note.UpdatedAtUtc.ToLocalTime()</div>
                        <div class="note-card-footer">
                            <form asp-action="Delete" asp-route-id="@note.Id" method="post" onsubmit="return confirm('¿Eliminar esta nota?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Eliminar</button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
