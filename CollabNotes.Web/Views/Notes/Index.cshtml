@model CollabNotes.Web.Models.Notes.NotesIndexViewModel

@{
    ViewData["Title"] = "Mis notas";
}

<h1>Mis notas</h1>

<div class="row">
    <div class="col-md-3">
        <h5>Carpetas</h5>
        <ul class="list-group mb-3">
            <li class="list-group-item @(Model.SelectedFolderId is null ? "active" : "")">
                <a class="@(Model.SelectedFolderId is null ? "text-white" : "")" asp-action="Index">Todas</a>
            </li>
            @foreach (var folder in Model.Folders)
            {
                <li class="list-group-item @(Model.SelectedFolderId == folder.Id ? "active" : "")">
                    <a class="@(Model.SelectedFolderId == folder.Id ? "text-white" : "")" asp-action="Index" asp-route-folderId="@folder.Id">@folder.Name</a>
                </li>
            }
        </ul>

        <form asp-action="CreateFolder" method="post" class="d-flex">
            <input type="text" name="name" class="form-control form-control-sm me-2" placeholder="Nueva carpeta" required />
            <button type="submit" class="btn btn-sm btn-outline-secondary">Crear</button>
        </form>
    </div>

    <div class="col-md-9">
        <a class="btn btn-primary mb-3" asp-action="Create" asp-route-folderId="@Model.SelectedFolderId">+ Nueva nota</a>

        @if (!Model.Notes.Any())
        {
            <p class="text-muted">No hay notas todavía.</p>
        }

        <div class="list-group">
            @foreach (var note in Model.Notes)
            {
                <div class="list-group-item d-flex justify-content-between align-items-center">
                    <a asp-action="Edit" asp-route-id="@note.Id">
                        <strong>@note.Title</strong>
                        <div class="text-muted small">Actualizada: @note.UpdatedAtUtc.ToLocalTime()</div>
                    </a>
                    <form asp-action="Delete" asp-route-id="@note.Id" method="post" onsubmit="return confirm('¿Eliminar esta nota?');">
                        <button type="submit" class="btn btn-sm btn-outline-danger">Eliminar</button>
                    </form>
                </div>
            }
        </div>
    </div>
</div>
