@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="surface-card p-4">
    <h1 class="text-danger mb-1">Error</h1>
    <h2 class="h5 text-muted mb-3">Ocurrió un error al procesar tu solicitud.</h2>

    @if (Model.ShowRequestId)
    {
        <p>
            <strong>Request ID:</strong> <code>@Model.RequestId</code>
        </p>
    }

    <hr class="my-3" />

    <h3 class="h6">Modo de desarrollo</h3>
    <p class="text-muted mb-2">
        Cambiar al entorno <strong>Development</strong> mostrará información más detallada sobre el error que ocurrió.
    </p>
    <p class="text-muted mb-0">
        <strong>El entorno Development no debe habilitarse en aplicaciones desplegadas.</strong>
        Puede exponer información sensible de las excepciones a los usuarios finales.
        Para depurar localmente, habilita el entorno <strong>Development</strong> configurando la variable de entorno <strong>ASPNETCORE_ENVIRONMENT</strong> en <strong>Development</strong>
        y reiniciando la aplicación.
    </p>
</div>
