@{
    ViewData["Title"] = "CollabNotes";
}

<div class="surface-card p-5 text-center">
    <span class="app-brand-mark mx-auto mb-3" style="width:3rem;height:3rem;font-size:1.2rem;">CN</span>
    <h1 class="mb-2">Notas colaborativas en tiempo real</h1>
    <p class="text-muted mb-4">Escribe, comparte y edita notas junto a tu equipo, con presencia en vivo e historial de cambios.</p>
    <div class="d-flex justify-content-center gap-2">
        <a class="btn btn-primary" asp-controller="Notes" asp-action="Index">Ir a mis notas</a>
        <a class="btn btn-outline-secondary" asp-area="Identity" asp-page="/Account/Register">Crear cuenta</a>
    </div>
</div>
